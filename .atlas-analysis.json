  "keyFeatures": [
    "TypeScript-first configuration API for defining content schemas",
    "No database — content stored as Markdown, YAML, or JSON files",
    "Built-in GitHub integration for collaborative content editing",
    "Works locally or with Keystatic Cloud for simplified auth",
    "First-class support for Next.js, Astro, and Remix",
    "Rich field types: text, image, markdoc, MDX, conditional, relationship, and more",
    "WYSIWYG editor with Markdoc and MDX support",
    "Reader API for type-safe content querying at build time",
    "Content components for embedding React components in rich-text fields",
    "Multiplayer editing (experimental) via Keystatic Cloud Pro"
  ],
  "publicApiSurface": [
    "config() — define the Keystatic configuration",
    "collection() — define a collection of content entries",
    "singleton() — define a single content entry",
